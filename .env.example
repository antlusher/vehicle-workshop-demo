# Root .env — used by Docker Compose on the server.
# Do NOT use this for local development.
#
# File ownership:
#   .env                → Docker Compose (EC2/prod). Edit this to change server config.
#   server/.env         → Local dev server (node / nodemon).
#   client/.env.development  → Local Vite dev (VITE_API_BASE_URL etc).
#   client/.env.production   → Production Vite build (leave VITE_API_BASE_URL empty = relative paths).

# Comma-separated origins the API will accept (subdomains of listed domains also allowed)
CLIENT_ORIGIN=https://yourgofer.com,https://customer.yourgofer.com

# Postgres credentials — must match what the db container is initialised with
POSTGRES_DB=workshop
POSTGRES_USER=workshop
POSTGRES_PASSWORD=workshop

# DATABASE_URL uses the internal Docker hostname 'db', not localhost
DATABASE_URL=postgresql://workshop:workshop@db:5432/workshop
