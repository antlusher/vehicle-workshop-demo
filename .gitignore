# Ignore everything by default, then selectively allow project files
*

# Keep git ignore itself
!.gitignore

# Allow project metadata and deployment files
!/README.md
!/package.json
!/package-lock.json
!/Dockerfile.backend
!/Dockerfile.frontend
!/docker-compose.yml
!/aws
!/aws/**

# Allow app directories and files
!/server
!/server/**
!/client
!/client/**
!/searxng
!/searxng/**

# Ignore frontend build output
/client/dist/

# Unignore node modules if needed for package locks only
/node_modules/
/client/node_modules/
/server/node_modules/

# Ignore environment files and IDE artifacts
/.env
/server/.env
!/.env.example
!/server/.env.example
.vscode/
.DS_Store
npm-debug.log*

# Large scraped/generated data — too big for git
server/data/scraped-*.json
server/data/wiki/
server/data/pdfs/

# Git worktrees — checked-out sibling directories
/worktrees/
